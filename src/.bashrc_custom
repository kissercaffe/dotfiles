# ghq
ghq-fzf() {
  local src=$(ghq list | fzf --preview "
    dir=\"\$(ghq root)/{}\"
    if ls \"\$dir\"/README.* &>/dev/null; then
      bat --color=always --style=header,grid --line-range :80 \"\$dir\"/README.*
    else
      echo 'NOT EXIST README'
    fi
  ")
  if [ -n "$src" ]; then
    cd "$(ghq root)/$src"
  fi
}
bind '"\C-xg": "\C-u ghq-fzf\C-m"'

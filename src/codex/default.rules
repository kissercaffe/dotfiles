# ── FORBIDDEN (deny) ──────────────────────────────────────────────────────────

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "No privilege escalation allowed",
)
prefix_rule(
    pattern = ["git", "reset"],
    decision = "forbidden",
    justification = "Destructive history rewrite not allowed",
)
prefix_rule(
    pattern = ["git", "rebase"],
    decision = "forbidden",
    justification = "Destructive history rewrite not allowed",
)
prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Recursive force delete is too dangerous",
)

# ── PROMPT (ask) ──────────────────────────────────────────────────────────────

prefix_rule(
    pattern = ["rm"],
    decision = "prompt",
    justification = "File deletion requires confirmation",
)
prefix_rule(
    pattern = ["chmod"],
    decision = "prompt",
    justification = "Permission changes require confirmation",
)
prefix_rule(
    pattern = ["wget"],
    decision = "prompt",
    justification = "Network download requires confirmation",
)
prefix_rule(
    pattern = ["curl"],
    decision = "prompt",
    justification = "Network request requires confirmation",
)
prefix_rule(
    pattern = ["git", "merge"],
    decision = "prompt",
    justification = "Merges require confirmation",
)

# ── ALLOW ─────────────────────────────────────────────────────────────────────

prefix_rule(pattern = ["mkdir"],           decision = "allow")
prefix_rule(pattern = ["touch"],           decision = "allow")
prefix_rule(pattern = ["ls"],              decision = "allow")
prefix_rule(pattern = ["tree"],            decision = "allow")
prefix_rule(pattern = ["mv"],              decision = "allow")
prefix_rule(pattern = ["cp"],              decision = "allow")
prefix_rule(pattern = ["cat"],             decision = "allow")
prefix_rule(pattern = ["grep"],            decision = "allow")
prefix_rule(pattern = ["find"],            decision = "allow")
prefix_rule(pattern = ["echo"],            decision = "allow")
prefix_rule(pattern = ["npm"],             decision = "allow")
prefix_rule(pattern = ["git", "add"],      decision = "allow")
prefix_rule(pattern = ["git", "commit"],   decision = "allow")
prefix_rule(pattern = ["git", "push"],     decision = "allow")
prefix_rule(pattern = ["git", "pull"],     decision = "allow")
prefix_rule(pattern = ["git", "branch"],   decision = "allow")
prefix_rule(pattern = ["git", "checkout"], decision = "allow")
prefix_rule(pattern = ["git", "status"],   decision = "allow")
prefix_rule(pattern = ["git", "log"],      decision = "allow")
prefix_rule(pattern = ["git", "diff"],     decision = "allow")
prefix_rule(pattern = ["git", "fetch"],    decision = "allow")
prefix_rule(pattern = ["gh", "pr"],        decision = "allow")
